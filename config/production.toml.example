# NIXI.TEL SBC - Production Configuration Example
#
# Copy this file to production.toml and fill in your values.
# Never commit production.toml to git.

[general]
name = "SBC-prod"
instance_id = "sbc-prod-01"
cdr_file = "/var/log/sbc/cdr.jsonl"

[network]
public_ipv4 = "YOUR_PUBLIC_IP"

# SIP UDP
[[network.listeners]]
transport = "UDP"
bind_address = "0.0.0.0"
bind_port = 5060

# SIP TCP
[[network.listeners]]
transport = "TCP"
bind_address = "0.0.0.0"
bind_port = 5060

# SIP TLS
[[network.listeners]]
transport = "TLS"
bind_address = "0.0.0.0"
bind_port = 5061
cert_file = "/etc/sbc/certs/fullchain.pem"
key_file = "/etc/sbc/certs/privkey.pem"

# WebRTC WSS
[[network.listeners]]
transport = "WSS"
bind_address = "0.0.0.0"
bind_port = 8443
cert_file = "/etc/sbc/certs/fullchain.pem"
key_file = "/etc/sbc/certs/privkey.pem"

[media]
rtp_port_range = [10000, 20000]
rtcp_enabled = true
transcoding_threads = 2
codecs = ["PCMU", "PCMA", "Opus", "G729"]
public_ip = "YOUR_PUBLIC_IP"

[media.webrtc]
enabled = true
stun_servers = ["stun:stun.example.com:3478"]
turn_enabled = true
turn_server = "turn:turn.example.com:3478"

[database]
postgres_url = "postgresql://sbc:CHANGE_ME@localhost/sbc_db"
postgres_max_connections = 10
redis_url = "redis://127.0.0.1:6379"

[security]
rate_limit_global = 500
rate_limit_per_ip = 30
auth_challenge_timeout = 30
sip_realm = "sip.example.com"
enable_digest_auth = true

[security.sip_users]
# user = "password"
alice = "CHANGE_ME"
bob = "CHANGE_ME"

[management]
api_enabled = true
api_bind_address = "127.0.0.1"
api_port = 8080
api_auth_token = "CHANGE_ME"

[metrics]
prometheus_enabled = true
prometheus_bind_address = "127.0.0.1"
prometheus_port = 9090

[logging]
level = "info"
file = "/var/log/sbc/sbc.log"

# ── Outbound PSTN Trunk ──────────────────────────────────────
[[trunks]]
name = "my-trunk"
host = "TRUNK_IP"
port = 5060
transport = "UDP"
enabled = true
auth_required = false
username = "YOUR_ACCOUNT_ID"
register_with_trunk = false
prefix_patterns = ["+33", "0"]
priority = 10
number_format = "national"
country_code = "33"
national_prefix = "0"
allowed_codecs = ["PCMU", "PCMA"]
max_concurrent_calls = 30

# ── Inbound DID Mappings ────────────────────────────────────
# Map incoming phone numbers to registered SIP users
[[dids]]
number = "0123456789"
user = "alice"

[[dids]]
number = "0123456790"
user = "bob"
